generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  BOOK
  AUDIOBOOK
  NOVEL
  COMIC
  MAGAZINE
  RESEARCH_PAPER
  MANUAL
  NEWSLETTER
}

enum SourceName {
  PROJECT_GUTENBERG
  OPEN_LIBRARY
  LIBRIVOX
  INTERNET_ARCHIVE
  STANDARD_EBOOKS
  MANYBOOKS
  FEEDBOOKS
  GOOGLE_BOOKS
  ARXIV
  DOAJ
  OAPEN
  UNGLUE_IT
  OPENSTAX
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
  likes     Like[]
  wishlists Wishlist[]
  favorites Favorite[]
  history   ReadHistory[]
  settings  UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Book {
  id            String      @id @default(cuid())
  slug          String      @unique
  title         String
  author        String
  description   String      @db.Text
  coverUrl      String?
  contentType   ContentType @default(BOOK)
  language      String      @default("en")
  isbn          String?
  publisher     String?
  publishYear   Int?
  pageCount     Int?
  narrator      String?
  duration      Int?
  rating        Float       @default(0)
  ratingCount   Int         @default(0)
  viewCount     Int         @default(0)
  likeCount     Int         @default(0)
  downloadCount Int         @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  formats  BookFormat[]
  sources  BookSource[]
  tags     BookTag[]
  likes    Like[]
  wishlists Wishlist[]
  favorites Favorite[]
  history   ReadHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([contentType])
  @@index([slug])
  @@index([viewCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model Category {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String @db.Text
  icon        String?
  bookCount   Int    @default(0)
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  books       Book[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([parentId])
}

model BookFormat {
  id       String @id @default(cuid())
  bookId   String
  format   String
  fileSize Int?
  url      String

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, format])
}

model BookSource {
  id         String     @id @default(cuid())
  bookId     String
  source     SourceName
  externalId String
  url        String
  lastSync   DateTime   @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([source, externalId])
  @@index([bookId])
}

model BookTag {
  id     String @id @default(cuid())
  bookId String
  tag    String

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, tag])
  @@index([tag])
}

model Like {
  id     String @id @default(cuid())
  userId String
  bookId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Wishlist {
  id     String @id @default(cuid())
  userId String
  bookId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Favorite {
  id     String @id @default(cuid())
  userId String
  bookId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model ReadHistory {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  progress  Float    @default(0)
  startedAt DateTime @default(now())
  lastRead  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  data   Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String   @db.Text
  content     String   @db.Text
  coverImage  String?
  author      String
  tags        String[]
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([publishedAt(sort: Desc)])
}

model ScrapeJob {
  id        String     @id @default(cuid())
  source    SourceName
  status    String     @default("pending")
  startedAt DateTime?
  endedAt   DateTime?
  itemCount Int        @default(0)
  errors    String[]
  createdAt DateTime   @default(now())

  @@index([source])
  @@index([createdAt(sort: Desc)])
}
